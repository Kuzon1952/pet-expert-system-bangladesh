<mxfile host="app.diagrams.net" agent="Codex">
  <diagram id="bd-pet-selection-v2" name="Выбор животного — Бангладеш">
    <mxGraphModel dx="1144" dy="768" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" value="Выбор домашнего животного на основе заданных характеристик (Choosing a Pet Based on Given Characteristics)&lt;br&gt;&lt;font style=&quot;font-size:12px;font-weight:normal;&quot;&gt;Область: распространённые безопасные домашние животные, доступные в Бангладеш (&lt;strong data-start=&quot;53&quot; data-end=&quot;64&quot;&gt;Domain:&lt;/strong&gt; Common safe pets available in Bangladesh)&lt;/font&gt;" vertex="1">
          <mxGeometry height="55" width="2000" x="300" y="10" as="geometry" />
        </mxCell>
        <mxCell id="legend" parent="1" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;" value="─── да&lt;br&gt;- - - нет" vertex="1">
          <mxGeometry height="45" width="90" x="1254" y="180" as="geometry" />
        </mxCell>
        <mxCell id="n1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="Вам важно ежедневное близкое общение с питомцем?&lt;div&gt;Is daily close interaction with your pet important to you?&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="280" x="1159" y="80" as="geometry" />
        </mxCell>
        <mxCell id="n2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Готовы уделять 1+ час в день на прогулки и дрессировку?&lt;br&gt;Are you ready to spend 1+ hour per day on walks and training?" vertex="1">
          <mxGeometry height="80" width="270" x="514" y="210" as="geometry" />
        </mxCell>
        <mxCell id="n3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="Предпочитаете питомца для пассивного наблюдения?&lt;br&gt;Do you prefer a pet for passive observation?" vertex="1">
          <mxGeometry height="80" width="270" x="1814" y="210" as="geometry" />
        </mxCell>
        <mxCell id="n4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="Предпочитаете питомца, которому нужно пространство для активного движения вне клетки?&lt;div&gt;Do you prefer a pet that needs space for active movement outside a cage?&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="214" y="380" as="geometry" />
        </mxCell>
        <mxCell id="n5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="Нужно компактное животное для жизни в квартире?&lt;br&gt;Do you need a compact pet suitable for apartment living?" vertex="1">
          <mxGeometry height="80" width="240" x="844" y="380" as="geometry" />
        </mxCell>
        <mxCell id="n6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="Готовы ухаживать за аквариумом и регулярно менять воду?&lt;br&gt;Are you ready to maintain an aquarium and regularly change the water?" vertex="1">
          <mxGeometry height="80" width="240" x="1514" y="380" as="geometry" />
        </mxCell>
        <mxCell id="n7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="Нужен питомец для общения и игр (без активного выгула)?&lt;div&gt;Do you want a pet for interaction and play (without active walking)?&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="2144" y="380" as="geometry" />
        </mxCell>
        <mxCell id="n8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#60a917;strokeColor=#2D7600;fontSize=11;fontColor=#ffffff;" value="Нужен питомец с хорошей обучаемостью и послушанием?&lt;div&gt;&lt;strong data-start=&quot;308&quot; data-end=&quot;367&quot; style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;Do you need a pet with good trainability and obedience?&lt;/font&gt;&lt;/strong&gt;&lt;div&gt;&lt;br&gt;&lt;p data-start=&quot;369&quot; data-end=&quot;389&quot;&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="57" y="560" as="geometry" />
        </mxCell>
        <mxCell id="n9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;strokeColor=#005700;fontSize=11;fontColor=#ffffff;" value="Предпочитаете питомца с независимым характером?&lt;div&gt;&lt;p data-start=&quot;416&quot; data-end=&quot;526&quot;&gt;&lt;strong data-start=&quot;470&quot; data-end=&quot;526&quot;&gt;Do you prefer a pet with an independent personality?&lt;/strong&gt;&lt;/p&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="372" y="560" as="geometry" />
        </mxCell>
        <mxCell id="n10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;strokeColor=#005700;fontSize=11;fontColor=#ffffff;" value="Нормально относитесь к ночной активности питомца?&lt;div&gt;Are you comfortable with a pet being active at night?&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="240" x="687" y="560" as="geometry" />
        </mxCell>
        <mxCell id="n11" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;strokeColor=#005700;fontSize=11;fontColor=#ffffff;" value="Нужен очень тихий и спокойный питомец?&lt;br&gt;Do you need a very quiet and calm pet?" vertex="1">
          <mxGeometry height="80" width="240" x="1002" y="560" as="geometry" />
        </mxCell>
        <mxCell id="n12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#008a00;strokeColor=#005700;fontSize=11;fontColor=#ffffff;" value="Хотите групповой аквариум с несколькими рыбками?&lt;br&gt;Do you want a community aquarium with several fish?" vertex="1">
          <mxGeometry height="80" width="240" x="1357" y="560" as="geometry" />
